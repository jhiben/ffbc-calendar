@page
@model ListEventsModel
@{
    ViewData["Title"] = "Upcoming Events";
}

<h1>Upcoming Events</h1>

@if (!Model.Events.Any())
{
    <div class="alert alert-info mt-3">No upcoming events.</div>
}
else
{
    <div class="table-responsive mt-3">
        <table class="table">
            <thead>
                <tr>
                    <th style="width:160px">Date</th>
                    <th>Event</th>
                    <th>Notes</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var ev in Model.Events)
                {
                    <tr>
                        <td class="text-nowrap fw-semibold" style="color:var(--color-text-muted);font-size:var(--font-size-sm)">@ev.Date.ToString("ddd, MMM d yyyy")</td>
                        <td><a asp-page="/EventDetail" asp-route-date="@ev.Date.ToString("yyyy-MM-dd")"
                                   asp-route-title="@ev.Title">@ev.Title</a></td>
                        <td class="text-muted" style="font-size:var(--font-size-sm)">@(ev.Notes ?? string.Empty)</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
