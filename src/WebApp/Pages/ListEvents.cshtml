@page
@model ListEventsModel
@{
    ViewData["Title"] = "List View";
}

<h1>Upcoming Events</h1>

@if (!Model.Events.Any())
{
    <p class="text-muted">No upcoming events.</p>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Date</th>
                <th>Title</th>
                <th>Notes</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var ev in Model.Events)
            {
                <tr>
                    <td>@ev.Date.ToString("ddd, MMM d yyyy")</td>
                    <td>@ev.Title</td>
                    <td>@(ev.Notes ?? string.Empty)</td>
                </tr>
            }
        </tbody>
    </table>
}
