@page
@model FFBC.Pages.EventDetailModel
@{
    ViewData["Title"] = Model.EventItem?.Title ?? "Event Not Found";
}

@if (Model.EventNotFound)
{
    <div class="alert alert-warning">
        <h4>Event Not Found</h4>
        <p>The requested event could not be found.</p>
        <a asp-page="/ListEvents" class="btn btn-primary">Back to Event List</a>
    </div>
}
else
{
    var ev = Model.EventItem!;
    var details = Model.EnrichedDetails;
    <h1>@ev.Title</h1>

    <div class="card detail-section">
        <div class="card-header">
            <h5 class="mb-0">📍 General Information</h5>
        </div>
        <div class="card-body">
            <dl class="row mb-0">
                <dt class="col-sm-3">Date</dt>
                <dd class="col-sm-9">@ev.Date.ToString("dddd, MMMM d yyyy")</dd>

                @if (!string.IsNullOrWhiteSpace(ev.Town))
                {
                    <dt class="col-sm-3">Town</dt>
                    <dd class="col-sm-9">@ev.Town</dd>
                }

                @if (!string.IsNullOrWhiteSpace(ev.PostalCode))
                {
                    <dt class="col-sm-3">Postal Code</dt>
                    <dd class="col-sm-9">@ev.PostalCode</dd>
                }

                @if (!string.IsNullOrWhiteSpace(ev.Country))
                {
                    <dt class="col-sm-3">Country</dt>
                    <dd class="col-sm-9">@ev.Country</dd>
                }

                @if (!string.IsNullOrWhiteSpace(ev.Province))
                {
                    <dt class="col-sm-3">Province</dt>
                    <dd class="col-sm-9">@ev.Province</dd>
                }

                @if (!string.IsNullOrWhiteSpace(ev.Challenge))
                {
                    <dt class="col-sm-3">Challenge</dt>
                    <dd class="col-sm-9">@ev.Challenge</dd>
                }

                @if (!string.IsNullOrWhiteSpace(ev.Notes))
                {
                    <dt class="col-sm-3">Notes</dt>
                    <dd class="col-sm-9">@ev.Notes</dd>
                }
            </dl>
        </div>
    </div>

    @if (details is not null)
    {
        var hasEnrichedContent = !string.IsNullOrWhiteSpace(details.StartLocation)
            || !string.IsNullOrWhiteSpace(details.Club)
            || details.Activities.Count > 0
            || !string.IsNullOrWhiteSpace(details.Notes)
            || !string.IsNullOrWhiteSpace(details.Website);

        if (hasEnrichedContent)
        {
            <div class="card mt-3 detail-section">
                <div class="card-header">
                    <h5 class="mb-0">ℹ️ Additional Details</h5>
                </div>
                <div class="card-body">
                    <dl class="row mb-0">
                        @if (!string.IsNullOrWhiteSpace(details.StartLocation))
                        {
                            <dt class="col-sm-3">Start Location</dt>
                            <dd class="col-sm-9">
                                @details.StartLocation
                                @if (!string.IsNullOrWhiteSpace(details.Address))
                                {
                                    <br /><span class="text-muted">@details.Address</span>
                                }
                                @if (!string.IsNullOrWhiteSpace(details.MapsUrl))
                                {
                                    <br /><a href="@details.MapsUrl" target="_blank" rel="noopener">Directions</a>
                                }
                            </dd>
                        }

                        @if (!string.IsNullOrWhiteSpace(details.Club))
                        {
                            <dt class="col-sm-3">Club</dt>
                            <dd class="col-sm-9">@details.Club</dd>
                        }

                        @if (!string.IsNullOrWhiteSpace(details.Website))
                        {
                            <dt class="col-sm-3">Website</dt>
                            <dd class="col-sm-9"><a href="@details.Website" target="_blank" rel="noopener">@details.Website</a></dd>
                        }

                        @if (!string.IsNullOrWhiteSpace(details.RegistrationUrl))
                        {
                            <dt class="col-sm-3">Registration</dt>
                            <dd class="col-sm-9"><a href="@details.RegistrationUrl" target="_blank" rel="noopener"
                                                        class="btn btn-sm btn-primary">Register Now →</a></dd>
                        }

                        @if (!string.IsNullOrWhiteSpace(details.Notes))
                        {
                            <dt class="col-sm-3">Notes</dt>
                            <dd class="col-sm-9">@details.Notes</dd>
                        }
                    </dl>
                </div>
            </div>

            @if (details.Activities.Count > 0)
            {
                <div class="card mt-3 detail-section">
                    <div class="card-header">
                        <h5 class="mb-0">🚴 Activities</h5>
                    </div>
                    <div class="table-responsive">
                        <table class="table mb-0">
                            <thead>
                                <tr>
                                    <th>Type</th>
                                    <th>Distance</th>
                                    <th>D+</th>
                                    <th>Difficulty</th>
                                    <th>Time</th>
                                    <th>Ravito</th>
                                    <th>Price</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var activity in details.Activities)
                                {
                                    <tr>
                                        <td>@activity.Type</td>
                                        <td>@(activity.Distance ?? "—")</td>
                                        <td>@(activity.Elevation ?? "—")</td>
                                        <td>@(activity.Difficulty ?? "—")</td>
                                        <td>@(activity.Time ?? "—")</td>
                                        <td>@(activity.Ravito ?? "—")</td>
                                        <td>@(activity.Price ?? "—")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }
        }
    }

    <div class="mt-3">
        <a asp-page="/ListEvents" class="btn btn-outline-secondary">← Back to Event List</a>
    </div>
}
