@page
@model CalendarModel
@{
    ViewData["Title"] = $"{new DateTime(Model.DisplayYear, Model.DisplayMonth, 1):MMMM yyyy}";
    var today = DateTime.Today;
}

<div class="d-flex align-items-center mb-4 gap-3">
    <a class="btn btn-outline-secondary btn-sm" asp-page="/Calendar" asp-route-year="@Model.PrevYear"
           asp-route-month="@Model.PrevMonth">
        &laquo; Prev
    </a>
    <h1 class="mb-0">@ViewData["Title"]</h1>
    <a class="btn btn-outline-secondary btn-sm" asp-page="/Calendar" asp-route-year="@Model.NextYear"
           asp-route-month="@Model.NextMonth">
        Next &raquo;
    </a>
</div>

<div class="table-responsive">
    <table class="table table-bordered calendar-table">
        <thead>
            <tr>
                <th>Mon</th>
                <th>Tue</th>
                <th>Wed</th>
                <th>Thu</th>
                <th>Fri</th>
                <th>Sat</th>
                <th>Sun</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var week in Model.Weeks)
            {
                <tr>
                    @foreach (var day in week)
                    {
                        if (day.Date is null)
                        {
                            <td class="calendar-empty"></td>
                        }
                        else
                        {
                            var isToday = day.Date.Value.Date == today;
                            <td class="@(isToday ? "calendar-today" : "")">
                                <div class="calendar-day-number">@day.Date.Value.Day</div>
                                @foreach (var ev in day.Events)
                                {
                                    <a asp-page="/EventDetail" asp-route-date="@ev.Date.ToString("yyyy-MM-dd")" asp-route-title="@ev.Title" class="event-chip" title="@ev.Title">@ev.Title</a>
                                }
                            </td>
                        }
                    }
                </tr>
            }
        </tbody>
    </table>
</div>
