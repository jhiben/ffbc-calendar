@page
@model FFBC.Pages.MapModel
@{
    ViewData["Title"] = "Map";
}

<h1>Event Map</h1>

@if (!Model.HasEvents)
{
    <div class="alert alert-info">No upcoming events.</div>
}

<div id="map" style="height: 500px; width: 100%;"></div>

@if (Model.UnmappedEvents.Count > 0)
{
    <h2 class="mt-4">Events Without Map Location</h2>
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Date</th>
                <th>Title</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var ev in Model.UnmappedEvents)
            {
                <tr>
                    <td>@ev.Date.ToString("ddd, MMM d yyyy")</td>
                    <td><a asp-page="/EventDetail" asp-route-date="@ev.Date.ToString("yyyy-MM-dd")" asp-route-title="@ev.Title">@ev.Title</a></td>
                </tr>
            }
        </tbody>
    </table>
}

@section Scripts {
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
          integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
          crossorigin="" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
            integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo="
            crossorigin=""></script>
    <style>
        .leaflet-control-locate {
            background-color: white;
            width: 34px;
            height: 34px;
            border-radius: 4px;
            box-shadow: 0 1px 5px rgba(0,0,0,0.4);
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .leaflet-control-locate:hover {
            background-color: #f4f4f4;
        }
        .leaflet-control-locate svg {
            width: 20px;
            height: 20px;
            fill: #333;
        }
    </style>
    <script>
        (function () {
            var markers = @Html.Raw(Model.MarkersJson);
            var belgiumCenter = [50.5, 4.5];
            var defaultZoom = 8;
            var userLocationZoom = 10; // ~50km radius

            // Request user geolocation with 5-second timeout
            // Returns Promise resolving to {lat, lng} or null on failure
            function getUserLocation() {
                return new Promise(function (resolve) {
                    if (!navigator.geolocation) {
                        resolve(null);
                        return;
                    }

                    navigator.geolocation.getCurrentPosition(
                        function (position) {
                            resolve({
                                lat: position.coords.latitude,
                                lng: position.coords.longitude
                            });
                        },
                        function (error) {
                            // Permission denied, unavailable, or other error - resolve null silently
                            resolve(null);
                        },
                        {
                            timeout: 5000,
                            enableHighAccuracy: false,
                            maximumAge: 300000 // Cache for 5 minutes
                        }
                    );
                });
            }

            // Create custom Leaflet control for location button
            var LocateControl = L.Control.extend({
                options: {
                    position: 'bottomright'
                },

                onAdd: function (map) {
                    var container = L.DomUtil.create('div', 'leaflet-control-locate leaflet-bar');
                    container.innerHTML = '<svg viewBox="0 0 24 24"><path d="M12 8c-2.21 0-4 1.79-4 4s1.79 4 4 4 4-1.79 4-4-1.79-4-4-4zm8.94 3A8.994 8.994 0 0 0 13 3.06V1h-2v2.06A8.994 8.994 0 0 0 3.06 11H1v2h2.06A8.994 8.994 0 0 0 11 20.94V23h2v-2.06A8.994 8.994 0 0 0 20.94 13H23v-2h-2.06zM12 19c-3.87 0-7-3.13-7-7s3.13-7 7-7 7 3.13 7 7-3.13 7-7 7z"/></svg>';
                    container.title = 'Center on my location';

                    L.DomEvent.disableClickPropagation(container);
                    L.DomEvent.on(container, 'click', function () {
                        getUserLocation().then(function (coords) {
                            if (coords) {
                                map.setView([coords.lat, coords.lng], userLocationZoom);
                            }
                        });
                    });

                    return container;
                }
            });

            // Initialize map with Belgium center initially
            var map = L.map('map').setView(belgiumCenter, defaultZoom);

            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors',
                maxZoom: 19
            }).addTo(map);

            // Add markers to map
            var markerGroup = null;
            if (markers.length > 0) {
                markerGroup = L.featureGroup();
                markers.forEach(function (m) {
                    var marker = L.marker([m.lat, m.lng]);
                    marker.bindPopup(
                        '<strong><a href="' + m.detailUrl + '">' + m.title + '</a></strong><br/>' +
                        m.date + '<br/>' +
                        m.town
                    );
                    markerGroup.addLayer(marker);
                });
                markerGroup.addTo(map);
            }

            // Add locate control
            new LocateControl().addTo(map);

            // Request geolocation and center map
            getUserLocation().then(function (coords) {
                if (coords) {
                    // Center on user location with 50km radius zoom
                    map.setView([coords.lat, coords.lng], userLocationZoom);
                } else if (markerGroup) {
                    // Fall back to fitting all markers
                    map.fitBounds(markerGroup.getBounds().pad(0.1));
                }
                // If no coords and no markers, keep Belgium center (already set)
            });
        })();
    </script>
}
