@page
@model FFBC.Pages.MapModel
@{
    ViewData["Title"] = "Map";
}

<h1>Event Map</h1>

@if (!Model.HasEvents)
{
    <div class="alert alert-info">No upcoming events.</div>
}

<div id="map" style="height: 500px; width: 100%;"></div>

@if (Model.UnmappedEvents.Count > 0)
{
    <h2 class="mt-4">Events Without Map Location</h2>
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Date</th>
                <th>Title</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var ev in Model.UnmappedEvents)
            {
                <tr>
                    <td>@ev.Date.ToString("ddd, MMM d yyyy")</td>
                    <td><a asp-page="/EventDetail" asp-route-date="@ev.Date.ToString("yyyy-MM-dd")" asp-route-title="@ev.Title">@ev.Title</a></td>
                </tr>
            }
        </tbody>
    </table>
}

@section Scripts {
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
          integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
          crossorigin="" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
            integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo="
            crossorigin=""></script>
    <script>
        (function () {
            var markers = @Html.Raw(Model.MarkersJson);
            var belgiumCenter = [50.5, 4.5];
            var defaultZoom = 8;

            var map = L.map('map').setView(belgiumCenter, defaultZoom);

            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors',
                maxZoom: 19
            }).addTo(map);

            if (markers.length > 0) {
                var group = L.featureGroup();
                markers.forEach(function (m) {
                    var marker = L.marker([m.lat, m.lng]);
                    marker.bindPopup(
                        '<strong><a href="' + m.detailUrl + '">' + m.title + '</a></strong><br/>' +
                        m.date + '<br/>' +
                        m.town
                    );
                    group.addLayer(marker);
                });
                group.addTo(map);
                map.fitBounds(group.getBounds().pad(0.1));
            }
        })();
    </script>
}
