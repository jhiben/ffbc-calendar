<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - FFBC Calendar</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/WebApp.styles.css" asp-append-version="true" />
    <link rel="alternate" type="application/rss+xml" title="FFBC Calendar Events" href="/feed.xml" />
</head>

<body>
    @{
        var currentPage = ViewContext.RouteData.Values["page"]?.ToString()?.ToLowerInvariant() ?? "";
        string NavClass(string page) => currentPage == page.ToLowerInvariant() ? "nav-link active" : "nav-link";
    }
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-dark mb-3">
            <div class="container">
                <a class="navbar-brand" asp-area="" asp-page="/Index">🚵 FFBC Calendar</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse"
                        aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="@NavClass("/Index")" asp-area="" asp-page="/Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="@NavClass("/ListEvents")" asp-area="" asp-page="/ListEvents">List</a>
                        </li>
                        <li class="nav-item">
                            <a class="@NavClass("/Calendar")" asp-area="" asp-page="/Calendar">Calendar</a>
                        </li>
                        <li class="nav-item">
                            <a class="@NavClass("/Map")" asp-area="" asp-page="/Map">Map</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="footer">
        <div class="container">
            &copy; 2026 FFBC Calendar &mdash; <a asp-area="" asp-page="/Privacy">Privacy</a> &mdash; <a href="/feed.xml" title="RSS Feed">📡 RSS</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>
