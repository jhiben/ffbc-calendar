@page
@model IndexModel
@{
    ViewData["Title"] = "Home";
}

<div class="hero">
    <h1>🚵 FFBC Mountain Bike Events</h1>
    <p class="hero-sub">Find and plan your next FFBC-licensed mountain bike event across Belgium.</p>
</div>

<div class="nav-cards">
    <a asp-page="/ListEvents" class="nav-card">
        <span class="nav-card-icon">📋</span>
        <span>Event List</span>
    </a>
    <a asp-page="/Calendar" class="nav-card">
        <span class="nav-card-icon">📅</span>
        <span>Calendar</span>
    </a>
    <a asp-page="/Map" class="nav-card">
        <span class="nav-card-icon">🗺️</span>
        <span>Map</span>
    </a>
</div>
